{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API (cmd/api)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/api/main.go",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "API_DEBUG": "true"
      }
    },
    {
      "name": "Watcher (cmd/watcher)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/watcher/main.go",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "WORKERS_DEBUG": "true"
      }
    }
  ]
}
