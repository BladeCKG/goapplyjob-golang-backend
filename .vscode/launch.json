{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "API (cmd/api)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/api/main.go",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "API_DEBUG": "true"
      }
    },
    {
      "name": "Watcher (cmd/watcher)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/watcher/main.go",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "WORKERS_DEBUG": "true"
      }
    },
    {
      "name": "Importer (cmd/importer)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/importer/main.go",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "WORKERS_DEBUG": "true"
      }
    },
    {
      "name": "Raw Job Worker (cmd/rawjobworker)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/rawjobworker/main.go",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "WORKERS_DEBUG": "true"
      }
    },
    {
      "name": "Parsed Job Worker (cmd/parsedjobworker)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/parsedjobworker/main.go",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "WORKERS_DEBUG": "true"
      }
    },
    {
      "name": "Parsed AI Classifier Worker (cmd/parsedjobaiclassifierworker)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/parsedjobaiclassifierworker/main.go",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "WORKERS_DEBUG": "true"
      }
    },
    {
      "name": "Worker Chain (cmd/workerchain)",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/workerchain/main.go",
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "WORKERS_DEBUG": "true"
      }
    }
  ],
  "compounds": [
    {
      "name": "All Workers",
      "configurations": [
        "Watcher (cmd/watcher)",
        "Importer (cmd/importer)",
        "Raw Job Worker (cmd/rawjobworker)",
        "Parsed Job Worker (cmd/parsedjobworker)",
        "Parsed AI Classifier Worker (cmd/parsedjobaiclassifierworker)"
      ]
    }
  ]
}
